# ----------------------------
# Power BI
# ----------------------------

# Desktop files
*.pbix
*.pbit

# Legacy project / template artifacts
*.pbip.zip

# Power BI Desktop temp / cache / backups
*.tmp
*.bak

# PBIP local user state and cache
**/.pbi/
**/.pbicache/
**/.cache/

# Report-level local settings / editor state
**/*.Report/definition.pbir.local
**/*.Report/.pbi/
**/*.Report/.pbicache/

# Semantic model local settings / editor state
**/*.SemanticModel/.pbi/
**/*.SemanticModel/.pbicache/

# Optional: ignore all local files if your team creates them
**/*.local

