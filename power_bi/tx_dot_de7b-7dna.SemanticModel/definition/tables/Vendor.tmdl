	partition Vendor = m
		mode: import
		source =
				let
				    View = "vw_dim_vendor",
				    Host = #"Host",
				    Path = #"Path",
				    Catalog = #"Catalog",
				    Database = #"Database",
				    Limit = #"LimitData",
				    Source = Databricks.Catalogs(Host, Path, [Catalog = Catalog, Database = Database]),
				    /* Source = DuckDB.Contents(Host, Path, null, null, null, []), */
				    Data = Source{[Item=View,Schema=Database,Catalog=Catalog]}[Data],
				    ConditionalTopRows = if Limit then Table.FirstN(Data, 1000) else Data
				in
				    ConditionalTopRows

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

