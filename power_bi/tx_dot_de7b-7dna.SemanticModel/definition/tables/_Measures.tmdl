	measure 'Min Let Date' = ```
			
			CALCULATE (
			    MIN ( 'Project'[Project Actual Let Date] ),
			    REMOVEFILTERS ()
			)
			
			```
		formatString: yyyy-mm=dd
		lineageTag: 6ebe21ab-a435-4526-a335-d9c1f5d87a27

		annotation PBI_FormatHint = {"isCustom":true}

	measure 'Max Let Date' =
			
			CALCULATE (
			    MAX ( 'Project'[Project Actual Let Date] ),
			    REMOVEFILTERS ()
			)
		formatString: yyyy-mm-dd
		lineageTag: 64ea9af7-77e7-4aea-b524-ed144358a3bb

		annotation PBI_FormatHint = {"isCustom":true}

	measure 'Is In Let Date Range' =
			
			VAR CurrentDate =
			    MAX ( 'Calendar'[Calendar Date] )
			RETURN
			    IF (
			        CurrentDate >= [Min Let Date]
			            && CurrentDate <= [Max Let Date],
			        1,
			        0
			    )
		formatString: 0
		lineageTag: 009a8c1e-9b8e-4834-beb6-799f417ff59c

	measure 'Date In Active Range' =
			
			VAR MinDate =
			    CALCULATE ( MIN ( 'Project'[Project Actual Let Date] ), REMOVEFILTERS() )
			VAR MaxDate =
			    CALCULATE ( MAX ( 'Project'[Project Actual Let Date] ), REMOVEFILTERS() )
			VAR CurrentDate =
			    MAX ( 'Calendar'[Calendar Date] )
			RETURN
			    INT ( CurrentDate >= MinDate && CurrentDate <= MaxDate )
		formatString: 0
		lineageTag: 70448619-dc4a-46f0-b5b7-b051c454a808

	/// Total engineer's estimate across all bid items. Represents the baseline expected project cost used for comparison against submitted bids.
	measure 'Eng Est' = SUM('Item Comparison'[Estimate Extended Price])
		formatString: #,0;(#,0)
		displayFolder: Closed Project Detail
		lineageTag: edf26ba5-e1c0-46bb-817b-92e92aab166b

	/// Total value of the lowest (winning) bid across all items. This represents the awarded contract amount for the project.
	measure 1st = SUM('Item Comparison'[Winner Extended Price])
		formatString: #,0;(#,0)
		displayFolder: Closed Project Detail
		lineageTag: c918e268-7a95-4276-bce9-2b600e46e0e3

	/// Total value of the second-lowest bid across all items. Useful for understanding bid competitiveness and spread between top bidders.
	measure 2nd = SUM('Item Comparison'[Second Extended Price])
		formatString: #,0;(#,0)
		displayFolder: Closed Project Detail
		lineageTag: 0167227f-7926-4c35-9384-3cbcf4ff573b

	/// Difference between the winning bid and the second-lowest bid. Indicates how close the competition was for the awarded project.
	measure 1v2 = SUM('Item Comparison'[Winner Vs Second Amount])
		formatString: #,0;(#,0)
		displayFolder: Closed Project Detail
		lineageTag: e59c19ac-e253-49bb-b3e0-81fbede256de

	/// Total value of the focus vendor’s bid across all items. Used to evaluate performance and competitiveness of the selected vendor.
	measure Focus = SUM('Item Comparison'[Focus Extended Price])
		formatString: #,0;(#,0)
		displayFolder: Closed Project Detail
		lineageTag: a9012c57-068c-4e89-8f38-f0712ef7765c

	/// Difference between the focus vendor’s bid and the benchmark (typically the winning bid). Shows how far the focus vendor was from winning.
	measure 1vFocus = SUM('Item Comparison'[Focus Vs Benchmark Amount])
		formatString: #,0;(#,0)
		displayFolder: Closed Project Detail
		lineageTag: cecae670-4c85-476b-9b11-1db24c76a6bb

	/// Model column in table _Measures.
	column Column1
		dataType: string
		lineageTag: f9a4f2ef-99ca-406d-b076-e25755d5eab1
		summarizeBy: none
		sourceColumn: Column1

		annotation SummarizationSetBy = Automatic

	partition _Measures = m
		mode: import
		source =
				let
				    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Column1 = _t]),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Column1", type text}})
				in
				    #"Changed Type"

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

