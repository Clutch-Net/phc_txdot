table _Measures
	lineageTag: cdfea9b3-6c16-4fdd-9267-8ec3596c1498

	measure 'Total Contract Awards 111' = ```
			
			    SUMX(
			        CALCULATETABLE(
			            VALUES('Project Bid Role Comparison'[Project ID]),
			            'Project Bid Role Comparison'[Focus Vendor Won Flag] = "TRUE"
			        ),
			        CALCULATE(
			            MAX('Project Bid Role Comparison'[Lowest Bid Amount In Project])
			        )
			    )
			```
		lineageTag: fe08d041-9011-4d9c-bb6c-964d7e909515

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Underbid Exposure 111' = ```
			
			    SUMX(
			        CALCULATETABLE(
			            VALUES('Project Bid Role Comparison'[Project ID]),
			            'Project Bid Role Comparison'[Focus Vendor Won Flag] = "TRUE"
			        ),
			        VAR FocusBid =
			            CALCULATE(
			                MAX('Project Bid Role Comparison'[Focus Bid Total Amount])
			            )
			        VAR BenchmarkBid =
			            CALCULATE(
			                MAX('Project Bid Role Comparison'[Benchmark Bid Total Amount])
			            )
			        VAR Diff = BenchmarkBid - FocusBid
			        RETURN
			            IF(Diff > 0, Diff)
			    )
			```
		lineageTag: c8196e0f-210f-4b61-9ea7-88f2ede18385

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Number of distinct projects where the focus vendor competed.
	measure Bid = ```
			
			    CALCULATE(
			        DISTINCTCOUNT('Project Bid Role Comparison'[Project ID]),
			        'Project Bid Role Comparison'[Focus Vendor Competed Flag] = TRUE
			    )
			```
		formatString: #,0;(#,0)
		displayFolder: Cards\Focus Vendor
		lineageTag: d07e5323-10a7-4505-8327-1d242d0b1b9f

	/// Number of distinct projects won by the focus vendor.
	measure Won = ```
			
			    CALCULATE(
			        DISTINCTCOUNT('Project Bid Role Comparison'[Project ID]),
			        'Project Bid Role Comparison'[Focus Vendor Won Flag] = TRUE
			    )
			```
		formatString: #,0;(#,0)
		displayFolder: Cards\Focus Vendor
		lineageTag: d2518244-286f-4723-8de6-7c444cb6bc12

	/// Projects bid but not won by the focus vendor.
	measure Lost = [Bid] - [Won]
		formatString: #,0;(#,0)
		displayFolder: Cards\Focus Vendor
		lineageTag: 1cac7ae4-d47b-4aae-8ac0-2a71bd970a5c

	/// Text summary showing bid, won, and lost project counts for the focus vendor.
	measure 'Bid - Won - Lost' = ```
			
			    VAR b = COALESCE([Bid], 0)
			    VAR w = COALESCE([Won], 0)
			    VAR l = COALESCE([Lost], 0)
			    RETURN
			        IF(
			            b = 0 && w = 0 && l = 0,
			            BLANK(),
			            FORMAT(b, "#,0")
			                & " - "
			                & FORMAT(w, "#,0")
			                & " - "
			                & FORMAT(l, "#,0")
			        )
			```
		displayFolder: Cards\Focus Vendor
		lineageTag: 04b6b92f-d165-4da4-95ab-df0474484ec3

	/// Win rate for the focus vendor.
	measure 'Win Rate' = DIVIDE([Won], [Bid])
		formatString: 0.00%;(0.00%)
		displayFolder: Cards\Focus Vendor
		lineageTag: 35a4a3af-ace0-49c8-9956-ea52922e9e49

	/// Total awarded contract value for projects won by the focus vendor.
	measure 'Total Contract Awards' = ```
			
			    SUMX(
			        CALCULATETABLE(
			            VALUES('Project Bid Role Comparison'[Project ID]),
			            'Project Bid Role Comparison'[Focus Vendor Won Flag] = TRUE
			        ),
			        CALCULATE(
			            MAX('Project Bid Role Comparison'[Lowest Bid Amount In Project])
			        )
			    )
			```
		formatString: $#,0;($#,0)
		displayFolder: Cards\Focus Vendor
		lineageTag: d0c8ee62-9410-47ea-9200-45b8362b465d

	/// Average awarded contract value for projects won by the focus vendor.
	measure 'Average Contract Award' = DIVIDE([Total Contract Awards], [Won]) + 0
		formatString: $#,0;($#,0)
		displayFolder: Cards\Focus Vendor
		lineageTag: 2719a5a3-0f2c-43c6-b808-96c1775f0aed

	/// Configured focus vendor name in the current filter context.
	measure 'Focus Vendor' = ```
			
			    SELECTEDVALUE(
			        'Project Bid Role Comparison'[Configured Focus Vendor Name],
			        ""
			    ) & ""
			```
		displayFolder: Cards\Focus Vendor
		lineageTag: f2b460c3-5988-436e-8e9e-adf5de91ca60

	/// For projects won by the focus vendor, total positive difference between benchmark bid total and focus vendor bid total.
	measure 'Underbid Exposure' = ```
			
			    SUMX(
			        CALCULATETABLE(
			            VALUES('Project Bid Role Comparison'[Project ID]),
			            'Project Bid Role Comparison'[Focus Vendor Won Flag] = TRUE
			        ),
			        VAR FocusBid =
			            CALCULATE(
			                MAX('Project Bid Role Comparison'[Focus Bid Total Amount])
			            )
			        VAR BenchmarkBid =
			            CALCULATE(
			                MAX('Project Bid Role Comparison'[Benchmark Bid Total Amount])
			            )
			        VAR Diff = BenchmarkBid - FocusBid
			        RETURN
			            IF(Diff > 0, Diff)
			    )
			```
		formatString: $#,0;($#,0)
		displayFolder: Cards\Focus Vendor
		lineageTag: fccc71ef-7dd6-4f51-9fe4-05cf1b087458

	/// Underbid exposure as a percentage of total focus vendor bids on won projects.
	measure 'Underbid Exposure Ratio' = ```
			
			    DIVIDE(
			        [Underbid Exposure],
			        SUMX(
			            CALCULATETABLE(
			                VALUES('Project Bid Role Comparison'[Project ID]),
			                'Project Bid Role Comparison'[Focus Vendor Won Flag] = TRUE
			            ),
			            CALCULATE(
			                MAX('Project Bid Role Comparison'[Focus Bid Total Amount])
			            )
			        )
			    )
			```
		formatString: 0.00%;(0.00%)
		displayFolder: Cards\Focus Vendor
		lineageTag: 292594bd-ba67-4a0f-85d3-3ae3b277e797

	/// For projects lost by the focus vendor, total positive difference between focus vendor bid total and benchmark bid total.
	measure Overbid = ```
			
			    SUMX(
			        CALCULATETABLE(
			            VALUES('Project Bid Role Comparison'[Project ID]),
			            'Project Bid Role Comparison'[Focus Vendor Competed Flag] = TRUE,
			            'Project Bid Role Comparison'[Focus Vendor Won Flag] <> TRUE
			        ),
			        VAR FocusBid =
			            CALCULATE(
			                MAX('Project Bid Role Comparison'[Focus Bid Total Amount])
			            )
			        VAR BenchmarkBid =
			            CALCULATE(
			                MAX('Project Bid Role Comparison'[Benchmark Bid Total Amount])
			            )
			        VAR Diff = FocusBid - BenchmarkBid
			        RETURN
			            IF(Diff > 0, Diff)
			    )
			```
		formatString: $#,0;($#,0)
		displayFolder: Cards\Focus Vendor
		lineageTag: b2cd21b0-4ceb-4cff-ad13-aadb732a4e88

	/// Overbid as a percentage of total focus vendor bids on lost projects.
	measure 'Overbid Ratio' = ```
			
			    DIVIDE(
			        [Overbid],
			        SUMX(
			            CALCULATETABLE(
			                VALUES('Project Bid Role Comparison'[Project ID]),
			                'Project Bid Role Comparison'[Focus Vendor Competed Flag] = TRUE,
			                'Project Bid Role Comparison'[Focus Vendor Won Flag] <> TRUE
			            ),
			            CALCULATE(
			                MAX('Project Bid Role Comparison'[Focus Bid Total Amount])
			            )
			        )
			    )
			```
		formatString: 0.00%;(0.00%)
		displayFolder: Cards\Focus Vendor
		lineageTag: 557fc5ba-2d58-4624-92bd-88c082eafdbe

	/// Name of the benchmark vendor in the current filter context.
	measure 'Benchmark Vendor' = ```
			
			    SELECTEDVALUE(
			        'Project Bid Role Comparison'[Benchmark Vendor Name],
			        ""
			    ) & ""
			```
		displayFolder: Cards\Benchmark Vendor
		lineageTag: c66a9b93-ee96-41fd-95a7-a7c635e7fe9e

	/// Total awarded contract value on projects where the benchmark vendor beat the focus vendor.
	measure 'Benchmark Vendor Contract Awards' = ```
			
			    SUMX(
			        CALCULATETABLE(
			            VALUES('Project Bid Role Comparison'[Project ID]),
			            'Project Bid Role Comparison'[Focus Vendor Lost Flag] = TRUE,
			            NOT ISBLANK('Project Bid Role Comparison'[Benchmark Vendor Name])
			        ),
			        CALCULATE(
			            MAX('Project Bid Role Comparison'[Lowest Bid Amount In Project])
			        )
			    )
			```
		formatString: $#,0;($#,0)
		displayFolder: Cards\Benchmark Vendor
		lineageTag: 99bf311e-0c16-47ab-9ab5-95a583fcd561

	/// Difference between total contract awards won by the focus vendor and total contract awards won by benchmark vendors against the focus vendor.
	measure 'Focus vs Benchmark Contract Award Delta' = [Total Contract Awards] - [Benchmark Vendor Contract Awards]
		formatString: $#,0;($#,0)
		displayFolder: Cards\Benchmark Vendor
		lineageTag: bdbb46e7-0ffd-4439-beec-11a7442659e3

	/// Name of the winning vendor in the current filter context.
	measure '1st Place Vendor' = ```
			
			    SELECTEDVALUE(
			        'Project Bid Role Comparison'[Winner Vendor Name],
			        ""
			    ) & ""
			```
		displayFolder: Cards\Any Vendor
		lineageTag: 3cb0cfbf-5562-46e8-b01b-ac4856644d2f

	/// Name of the second place vendor in the current filter context.
	measure '2nd Place Vendor' = ```
			
			    SELECTEDVALUE(
			        'Project Bid Role Comparison'[Second Vendor Name],
			        ""
			    ) & ""
			```
		displayFolder: Cards\Any Vendor
		lineageTag: bd65d691-0561-4f97-b416-cdb947fa3e0f

	/// Name of the selected vendor in the current filter context.
	measure 'Any Vendor' = SELECTEDVALUE('Vendor'[Vendor Name], "") & ""
		displayFolder: Cards\Any Vendor
		lineageTag: d16ffa9c-4cab-4440-b545-ce8fe1002996

	/// Number of distinct projects bid by the selected vendor.
	measure 'Any Vendor Bid' = DISTINCTCOUNT('Project Bids'[Project ID])
		formatString: #,0;(#,0)
		displayFolder: Cards\Any Vendor
		lineageTag: a256ebb2-9de7-419f-b828-af1a33bfcda3

	/// Number of distinct projects won by the selected vendor.
	measure 'Any Vendor Won' = ```
			
			    CALCULATE(
			        DISTINCTCOUNT('Project Bids'[Project ID]),
			        'Project Bids'[Is Low Bidder] = TRUE    )
			```
		formatString: #,0;(#,0)
		displayFolder: Cards\Any Vendor
		lineageTag: 4bfbbb2a-1c3b-49c6-bea2-391dae2c276f

	/// Number of distinct projects bid but not won by the selected vendor.
	measure 'Any Vendor Lost' = [Any Vendor Bid] - [Any Vendor Won]
		formatString: #,0;(#,0)
		displayFolder: Cards\Any Vendor
		lineageTag: dde76cce-666a-4604-8757-2270a0619aca

	/// Total amount bid by the selected vendor across all visible projects.
	measure 'Any Vendor Total Bids' = ```
			
			    SUMX(
			        VALUES('Project Bids'[Project ID]),
			        CALCULATE(
			            MAX('Project Bids'[Max Bid Total Amount])
			        )
			    )
			```
		formatString: $#,0;($#,0)
		displayFolder: Cards\Any Vendor
		lineageTag: ba86d7c1-4350-4d6b-bf1c-54775b7ee680

	/// Total contract value awarded to the selected vendor based on projects won.
	measure 'Any Vendor Total Contract Awards' = ```
			
			    SUMX(
			        CALCULATETABLE(
			            VALUES('Project Bids'[Project ID]),
			            'Project Bids'[Is Low Bidder] = TRUE
			        ),
			        CALCULATE(
			            MAX('Project Bids'[Max Bid Total Amount])
			        )
			    )
			```
		formatString: $#,0;($#,0)
		displayFolder: Cards\Any Vendor
		lineageTag: 97acebc4-6266-439d-815a-2a05d506dff8

	/// Share of total awarded contract value represented by the selected vendor in the current selection.
	measure 'Any Vendor % of Total Awarded' = ```
			
			    DIVIDE(
			        [Any Vendor Total Contract Awards],
			        CALCULATE(
			            SUMX(
			                VALUES('Project Bids'[Project ID]),
			                CALCULATE(
			                    MAX('Project Bids'[Max Bid Total Amount])
			                )
			            ),
			            REMOVEFILTERS('Vendor'),
			            'Project Bids'[Is Low Bidder] = TRUE
			        )
			    )
			```
		formatString: 0.00%;(0.00%)
		displayFolder: Cards\Any Vendor
		lineageTag: ed8cc192-9d33-4440-9b94-a5f1ba88f7a3

	/// Win rate for the selected vendor.
	measure 'Any Vendor Win Rate' = DIVIDE([Any Vendor Won], [Any Vendor Bid])
		formatString: 0.00%;(0.00%)
		displayFolder: Cards\Any Vendor
		lineageTag: da8f2d6a-9fc1-4920-8059-076340d8ed3e

	/// Weighted win ratio combining the selected vendor's win rate and share of total awarded contract value in the current selection.
	measure 'Any Vendor Weighted Win Ratio' = [Any Vendor Win Rate] * [Any Vendor % of Total Awarded]
		formatString: 0.00%;(0.00%)
		displayFolder: Cards\Any Vendor
		lineageTag: 753ecaa4-b877-4fe8-8fdc-50711613d2a1

	/// Average bid amount per project for the selected vendor.
	measure 'Any Vendor Average Bid' = DIVIDE([Any Vendor Total Bids], [Any Vendor Bid])
		formatString: $#,0;($#,0)
		displayFolder: Cards\Any Vendor
		lineageTag: 74002a28-b05d-4252-9155-5bcfeb61cbcc

	/// Average contract award amount for projects won by the selected vendor.
	measure 'Any Vendor Average Contract Award' = DIVIDE([Any Vendor Total Contract Awards], [Any Vendor Won])
		formatString: $#,0;($#,0)
		displayFolder: Cards\Any Vendor
		lineageTag: 363fd338-61a4-47fb-960f-2df63c0d5dc4

	/// Text summary showing bid, won, and lost project counts for the selected vendor.
	measure 'Any Vendor Bid - Won - Lost' = ```
			
			    FORMAT([Any Vendor Bid], "#,0")
			        & " - "
			        & FORMAT([Any Vendor Won], "#,0")
			        & " - "
			        & FORMAT([Any Vendor Lost], "#,0")
			```
		displayFolder: Cards\Any Vendor
		lineageTag: fd741499-7b27-4756-a574-dc6960bc44e3

	/// Number of projects where the focus vendor competed against the selected vendor.
	measure 'Times Competed Against Vendor' = ```
			
			    CALCULATE(
			        DISTINCTCOUNT('Project Bid Role Comparison'[Project ID]),
			        'Project Bid Role Comparison'[Focus Vendor Competed Flag] = TRUE,
			        'Project Bid Role Comparison'[Benchmark Vendor Name]
			            IN VALUES('Vendor'[Vendor Name])
			    )
			```
		formatString: #,0;(#,0)
		displayFolder: Cards\Competitor
		lineageTag: 4bcf077d-f909-429e-91aa-e7cdc523e754

	/// Number of projects where the focus vendor beat the selected vendor.
	measure 'Times Beat Vendor' = ```
			
			    CALCULATE(
			        DISTINCTCOUNT('Project Bid Role Comparison'[Project ID]),
			        'Project Bid Role Comparison'[Focus Vendor Won Flag] = TRUE,
			        'Project Bid Role Comparison'[Benchmark Vendor Name]
			            IN VALUES('Vendor'[Vendor Name])
			    )
			```
		formatString: #,0;(#,0)
		displayFolder: Cards\Competitor
		lineageTag: 2e074f95-2a5f-4ca3-8cda-adab37bcaf6f

	/// Number of projects where the focus vendor lost to the selected vendor.
	measure 'Times Lost to Vendor' = ```
			
			    CALCULATE(
			        DISTINCTCOUNT('Project Bid Role Comparison'[Project ID]),
			        'Project Bid Role Comparison'[Focus Vendor Lost Flag] = TRUE,
			        'Project Bid Role Comparison'[Benchmark Vendor Name]
			            IN VALUES('Vendor'[Vendor Name])
			    )
			```
		formatString: #,0;(#,0)
		displayFolder: Cards\Competitor
		lineageTag: b9c70c7e-ce9d-4f15-893b-90012988084e

	/// Win rate of the focus vendor against the selected vendor.
	measure 'Win Rate vs Vendor' = DIVIDE([Times Beat Vendor], [Times Competed Against Vendor])
		formatString: 0.00%;(0.00%)
		displayFolder: Cards\Competitor
		lineageTag: 552ab9d6-8691-4484-a062-6773671432a1

	/// Total contract awards for the selected vendor.
	measure 'Selected Vendor Contract Awards' = ```
			
			    SUMX(
			        CALCULATETABLE(
			            VALUES('Project Bid Role Comparison'[Project ID]),
			            'Project Bid Role Comparison'[Winner Vendor Name]
			                IN VALUES('Vendor'[Vendor Name])
			        ),
			        CALCULATE(
			            MAX('Project Bid Role Comparison'[Lowest Bid Amount In Project])
			        )
			    )
			```
		formatString: $#,0;($#,0)
		displayFolder: Cards\Competitor
		lineageTag: 08349a31-ced6-4c2f-83d0-491ab3a884df

	/// Number of projects won by the selected vendor.
	measure 'Selected Vendor Won' = ```
			
			    CALCULATE(
			        DISTINCTCOUNT('Project Bid Role Comparison'[Project ID]),
			        'Project Bid Role Comparison'[Winner Vendor Name]
			            IN VALUES('Vendor'[Vendor Name])
			    )
			```
		formatString: #,0;(#,0)
		displayFolder: Cards\Competitor
		lineageTag: df437995-51bb-4df3-8954-cebd3efadd0c

	/// Win rate for the selected vendor.
	measure 'Selected Vendor Win Rate' = DIVIDE([Selected Vendor Won], [Any Vendor Bid])
		formatString: 0.00%;(0.00%)
		displayFolder: Cards\Competitor
		lineageTag: 90c603a1-a885-4a41-bfe8-1624fc5f6419

	/// Net head-to-head win rate of the focus vendor against the selected vendor. Positive means the focus vendor wins more often; negative means the selected vendor wins more often.
	measure 'Net Win Rate vs Vendor' = ```
			
			    DIVIDE(
			        [Times Beat Vendor] - [Times Lost to Vendor],
			        [Times Competed Against Vendor]
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Cards\Competitor
		lineageTag: 4f182a18-b15a-4aa8-a30a-855a0c57bd79

	/// Net wins of the focus vendor against the selected vendor.
	measure 'Net Wins vs Vendor' = [Times Beat Vendor] - [Times Lost to Vendor]
		formatString: #,0;(#,0)
		displayFolder: Cards\Competitor
		lineageTag: d7d8c022-ea90-485c-9971-04196b2b580b

	/// Distinct count of projects at the current bid item/specification filter context.
	measure 'Distinct Project Count by Specification' = DISTINCTCOUNT('Project Bid Items'[Project ID])
		formatString: #,0;(#,0)
		displayFolder: Analysis\Item Comparison
		lineageTag: e54b9a9f-7a6a-41d4-9f1a-81e01baa6cfa

	/// Sum of focus-vs-benchmark amount at the item comparison grain.
	measure 'Focus vs Benchmark' = SUM('Item Comparison'[Focus Vs Benchmark Amount])
		formatString: $#,0;($#,0)
		displayFolder: Analysis\Item Comparison
		lineageTag: d0561ba4-8b60-4b6e-a31f-db554c43289a

	/// Absolute summed focus-vs-benchmark amount.
	measure 'ABS Focus vs Benchmark' = SUM('Item Comparison'[ABS Focus Vs Benchmark Amount])
		formatString: $#,0;($#,0)
		displayFolder: Analysis\Item Comparison
		lineageTag: 340a3373-790b-4bc0-bd5c-790e93787ee1

	/// At Item Work Category level, shows share of total absolute focus-vs-benchmark amount across selected categories. At Specification level, shows share within the parent work category.
	measure 'ABS % of Total Focus vs Benchmark' = ```
			
			    VAR _value = [ABS Focus vs Benchmark]
			    RETURN
			        SWITCH(
			            TRUE(),
			
			            ISINSCOPE('Item Comparison'[Specification]),
			                DIVIDE(
			                    _value,
			                    CALCULATE(
			                        [ABS Focus vs Benchmark],
			                        ALLSELECTED('Item Comparison'[Specification])
			                    )
			                ),
			
			            ISINSCOPE('Item Comparison'[Item Work Category]),
			                DIVIDE(
			                    _value,
			                    CALCULATE(
			                        [ABS Focus vs Benchmark],
			                        ALLSELECTED('Item Comparison'[Item Work Category])
			                    )
			                ),
			
			            DIVIDE(
			                _value,
			                CALCULATE(
			                    [ABS Focus vs Benchmark],
			                    ALLSELECTED('Item Comparison')
			                )
			            )
			        )
			```
		formatString: 0.00%;(0.00%)
		displayFolder: Analysis\Item Comparison
		lineageTag: 6123db48-3411-45d4-9037-f3c0b78bbea2

	/// Percent contribution of over/under bidding within each work category.
	measure 'ABS % by Over Under' = ```
			
			    DIVIDE(
			        [ABS Focus vs Benchmark],
			        CALCULATE(
			            [ABS Focus vs Benchmark],
			            ALLEXCEPT(
			                'Item Comparison',
			                'Item Comparison'[Item Work Category],
			                'Item Comparison'[Over Under Flag]
			            )
			        )
			    )
			```
		formatString: 0.00%;(0.00%)
		displayFolder: Analysis\Item Comparison
		lineageTag: 3779a97c-4fde-46e8-b414-22997db7f429

	/// Absolute amount where focus vendor overbid benchmark.
	measure 'Overbid Amount' = ```
			
			    CALCULATE(
			        [ABS Focus vs Benchmark],
			        'Item Comparison'[Over Under Flag] = "Overbid"
			    )
			```
		formatString: $#,0;($#,0)
		displayFolder: Analysis\Item Comparison
		lineageTag: b9358753-4457-4ddc-b6d5-5011b630d03f

	/// Absolute amount where focus vendor underbid benchmark.
	measure 'Underbid Amount' = ```
			
			    CALCULATE(
			        [ABS Focus vs Benchmark],
			        'Item Comparison'[Over Under Flag] = "Underbid"
			    )
			```
		formatString: $#,0;($#,0)
		displayFolder: Analysis\Item Comparison
		lineageTag: 3e0cb065-a628-49e4-9c79-6d0d87690828

	/// Net difference between focus and benchmark.
	measure 'Net Focus vs Benchmark' = SUM('Item Comparison'[Focus Vs Benchmark Amount])
		formatString: $#,0;($#,0)
		displayFolder: Analysis\Item Comparison
		lineageTag: 8be1c259-d69e-4d45-89ae-a7a574cf6111

	/// Percent of total impact where focus vendor underbid benchmark.
	measure 'Underbid %' = DIVIDE([Underbid Amount], [ABS Focus vs Benchmark])
		formatString: 0.00%;(0.00%)
		displayFolder: Analysis\Item Comparison
		lineageTag: cc105888-939b-4290-b455-9bf06fefb8d2

	/// Target underbid percentage.
	measure 'Underbid Target %' = 0.51
		formatString: 0.00%;(0.00%)
		displayFolder: Analysis\Item Comparison
		lineageTag: f37b849c-e83b-4d99-b1c3-1d6380b574e6

	/// Difference between actual and target underbid percentage.
	measure 'Underbid Variance %' = [Underbid %] - [Underbid Target %]
		formatString: 0.00%;(0.00%)
		displayFolder: Analysis\Item Comparison
		lineageTag: 6297abb5-48e4-4389-971e-f393e22c2367

	/// Status of underbid rate relative to target band.
	measure 'Bidding Strategy' = ```
			
			    VAR v = [Underbid %]
			    RETURN
			        SWITCH(
			            TRUE(),
			            v < 0.51, "Too Conservative",
			            v > 0.55, "Too Aggressive",
			            "On Target"
			        )
			```
		displayFolder: Analysis\Item Comparison
		lineageTag: e5295306-78ae-4efd-8047-792da480aacf

	/// Color indicator for underbid gauge.
	measure 'Underbid Color' = ```
			
			    VAR v = [Underbid %]
			    RETURN
			        SWITCH(
			            TRUE(),
			            v < 0.51, "#D9534F",
			            v > 0.55, "#D9534F",
			            "#5CB85C"
			        )
			```
		displayFolder: Analysis\Item Comparison
		lineageTag: 181a2095-d8ae-4f0e-9651-5d92d30b80a9

	/// Midpoint of target range.
	measure 'Underbid Target Mid' = 0.53
		formatString: 0.00%;(0.00%)
		displayFolder: Analysis\Item Comparison
		lineageTag: b6089aa6-545a-41d7-ba60-98cf705f93d3

	/// Count of project opportunities not pursued by the focus vendor.
	measure 'Missed Opportunities' = ```
			
			    CALCULATE(
			        DISTINCTCOUNT('Project Bid Role Comparison'[Project ID]),
			        'Project Bid Role Comparison'[Is Project Opportunity Flag] = "TRUE",
			        'Project Bid Role Comparison'[Focus Vendor Competed Flag] = "FALSE"
			    ) 
			```
		formatString: #,0;(#,0)
		displayFolder: Analysis\Opportunities
		lineageTag: 65298a4e-c16d-47ef-9175-4df85b68cbe8

	/// Count of opportunities where the focus vendor participated.
	measure 'Opportunity Participation Count' = ```
			
			    CALCULATE(
			        DISTINCTCOUNT('Project Bid Role Comparison'[Project ID]),
			        'Project Bid Role Comparison'[Focus Vendor Participated Opportunity Flag] = "TRUE"
			    )
			```
		formatString: #,0;(#,0)
		displayFolder: Analysis\Opportunities
		lineageTag: 43cf5562-f3de-4513-999f-29a830c5e046

	/// Count of opportunities where the focus vendor did not participate.
	measure 'Opportunity Non-Participation Count' = ```
			
			    CALCULATE(
			        DISTINCTCOUNT('Project Bid Role Comparison'[Project ID]),
			        'Project Bid Role Comparison'[Focus Vendor Missed Opportunity Flag] = "TRUE"
			    )
			```
		formatString: #,0;(#,0)
		displayFolder: Analysis\Opportunities
		lineageTag: 3eddd458-4549-43be-b5e5-cd198d9fe499

	/// Participation rate on project opportunities.
	measure 'Opportunity Participation Rate' = ```
			
			    DIVIDE(
			        [Opportunity Participation Count],
			        [Missed Opportunities]
			    )
			```
		formatString: 0.0%;(0.0%)
		displayFolder: Analysis\Opportunities
		lineageTag: 17c21141-aa3d-486e-bb46-6a367139e742

	/// Numeric map status code by location.
	measure 'Map Status Code' = ```
			
			    VAR _Bid = [Bid]
			    VAR _Won = [Won]
			    RETURN
			        SWITCH(
			            TRUE(),
			            _Bid = 0, 0,
			            _Bid > 0 && _Won = 0, 1,
			            _Won = 1, 2,
			            _Won > 1, 3,
			            BLANK()
			        )
			```
		formatString: #,0;(#,0)
		displayFolder: Map
		lineageTag: b1bfd6c5-5e91-43a1-8f4c-4a578e41d360

	/// Text map status by location.
	measure 'Map Status' = ```
			
			    SWITCH(
			        [Map Status Code],
			        0, "Never Bid",
			        1, "Bid, Never Won",
			        2, "Won Once",
			        3, "Won Multiple Times",
			        BLANK()
			    )
			```
		displayFolder: Map
		lineageTag: 6d81773b-5dd9-441c-b41a-fa8ccf716e51

	/// Indicator for whether the current focus bid code is in the targeted bid-code list.
	measure 'Is Target Focus Bid Code' =
			
			VAR _Code =
			    SELECTEDVALUE ( 'Item Comparison'[Focus Bid Code] )
