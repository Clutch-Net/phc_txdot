	column 'Specification Description'
		dataType: string
		lineageTag: 7298a21a-229c-4264-9cd8-bdd8207ea4ef
		summarizeBy: none
		sourceColumn: Specification Description

		annotation SummarizationSetBy = Automatic

	/// Normalized specification description used as the effective reporting description for the item specification.
