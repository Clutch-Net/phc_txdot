/// Conformed item specification dimension used to standardize specification-level grouping, labeling, and drillthrough across bid item, estimate item, and item comparison reporting.
table 'Item Specification'
	lineageTag: 1d7ce185-a502-483a-993c-678b82016b98

	/// Technical key for the item specification dimension. Used for model relationships only and hidden from report users.
	column 'Item Specification Key'
		dataType: string
		isHidden
		lineageTag: 3ddbff0a-85c2-4f4f-b578-691547f52a2f
		summarizeBy: none
		sourceColumn: Item Specification Key

		annotation SummarizationSetBy = Automatic

	/// Specification code associated with the item specification. Treated as a business code rather than an aggregating metric.
	column 'Specification Code'
		dataType: double
		formatString: #,0.00;(#,0.00)
		lineageTag: 206fa0ab-0ff7-409c-8494-0bab3834da40
		summarizeBy: none
		sourceColumn: Specification Code

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

