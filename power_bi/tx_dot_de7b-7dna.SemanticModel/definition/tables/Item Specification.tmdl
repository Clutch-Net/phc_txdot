		formatString: #,0;(#,0)
		lineageTag: 49669b62-70d2-49da-ae5c-ea38f28f320f
		summarizeBy: sum
		sourceColumn: Default Spec Book Year

		annotation SummarizationSetBy = Automatic

	/// Indicator showing whether the specification has been associated with more than one bid code in the source history.
	column 'Has Multiple Bid Codes'
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
